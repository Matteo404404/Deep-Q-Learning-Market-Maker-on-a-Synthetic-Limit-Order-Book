[build-system]
requires = ["setuptools>=64", "wheel"]
build-backend = "setuptools.backends.legacy:build"

[project]
name = "rl_market_maker"
version = "0.1.0"
description = "RL-driven market making with learned volatility"
requires-python = ">=3.10"
dependencies = [
    "numpy",
    "pandas",
    "gymnasium",
    "stable-baselines3[extra]",
    "torch",
    "pyyaml",
    "streamlit",
    "matplotlib",
    "quant_optiver",
]

[tool.setuptools.packages.find]
where = ["src"]
